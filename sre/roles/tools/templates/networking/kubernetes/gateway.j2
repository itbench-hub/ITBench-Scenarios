---
apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: {{ tools_instances.kubernetes_gateways.names.tools }}
  namespace: {{ tools_instances.kubernetes_gateways.namespace }}
spec:
  gatewayClassName: istio
  listeners:
    - name: http
      port: 80
      protocol: HTTP
      allowedRoutes:
        namespaces:
          from: Selector
          selector:
            matchLabels:
              it-bench/gateway: "true"
