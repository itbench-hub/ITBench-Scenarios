---
apiVersion: monitoring.coreos.com/v1
kind: PodMonitor
metadata:
  name: {{ tools_helm_releases.nginx_fabric_gateway.name }}
  namespace: {{ tools_helm_releases.nginx_fabric_gateway.namespace }}
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ tools_helm_releases.nginx_fabric_gateway.name }}
      app.kubernetes.io/instance: {{ tools_helm_releases.nginx_fabric_gateway.name }}
  endpoints:
    - interval: 30s
      port: metrics
